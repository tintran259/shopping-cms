{
  "collectionName": "components_nav_links",
  "info": {
    "displayName": "Link",
    "icon": "link"
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "page": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::landing-page.landing-page"
    },
    "url": {
      "type": "string"
    },
    "openInNewTab": {
      "type": "boolean",
      "default": false
    },
    "highlight": {
      "type": "boolean",
      "default": false
    },
    "highlightColor": {
      "type": "customField",
      "customField": "global::color"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "startAt": {
      "type": "datetime"
    },
    "endAt": {
      "type": "datetime"
    }
  }
}
