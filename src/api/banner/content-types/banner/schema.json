{
  "kind": "collectionType",
  "collectionName": "banners",
  "info": {
    "singularName": "banner",
    "pluralName": "banners",
    "displayName": "Banner"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "component",
      "component": "blocks.image",
      "repeatable": false
    },
    "zone": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich-text",
        "blocks.carousel"
      ]
    },
    "startAt": {
      "type": "datetime"
    },
    "endAt": {
      "type": "datetime"
    }
  }
}
