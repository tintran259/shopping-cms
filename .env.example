HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (PostgreSQL — matches docker-compose.yml)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=shopping_cms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Server process timezone (storage stays UTC; this only affects logs / server-side Date formatting)
TZ=Asia/Ho_Chi_Minh

# Storefront on-demand revalidation (optional; leave URL empty to disable)
STOREFRONT_REVALIDATE_URL=
REVALIDATE_SECRET=
CRON_ENABLED=true
